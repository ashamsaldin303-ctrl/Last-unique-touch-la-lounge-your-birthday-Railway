{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "noImplicitAny": true,
    // Task 2b: tighten TS strictness — promote additional safety checks
    // from "off" (default) to "on". Skipped the very strict options
    // (`noUncheckedIndexedAccess`, `exactOptionalPropertyTypes`) — those
    // would require wide refactors and are deferred to a future task.
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "mini-services",
    "scripts",
    "prisma",
    ".next",
    "out",
    "build",
    "examples",
    "skills",
    "upload",
    "download",
    "tool-results"
  ]
}
