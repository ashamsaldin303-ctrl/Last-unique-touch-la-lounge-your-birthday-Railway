# ===========================================
# Last Unique Touch — Environment Variables
# ===========================================
# Copy this file to .env and fill in values
# For Railway: set these in Settings → Variables

# === Database (Supabase PostgreSQL) ===
# Transaction pooler (runtime queries) — port 6543
DATABASE_URL="postgresql://postgres.[REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true&connect_timeout=15"
# Direct connection (migrations) — port 5432
DIRECT_URL="postgresql://postgres.[REF]:[PASSWORD]@db.[REF].supabase.co:5432/postgres"

# === Auth (REQUIRED in production) ===
# Admin login password (choose a strong one)
ADMIN_PASSWORD=""

# Session HMAC secret — generate with: openssl rand -hex 32
# MUST be >=32 characters
SESSION_SECRET=""

# === Webhook Security ===
# Payment webhook HMAC — generate with: openssl rand -hex 16
# MUST be >=16 characters
PAYMENT_WEBHOOK_SECRET=""

# === Production ===
NODE_ENV="production"
NEXT_PUBLIC_SITE_URL="https://your-app.up.railway.app"

# === Contact Info ===
NEXT_PUBLIC_WHATSAPP_NUMBER="965XXXXXXXX"

# === n8n Automation ===
N8N_WEBHOOK_URL=""
N8N_WEBHOOK_SECRET=""

# === Email (Resend) ===
RESEND_API_KEY=""
FROM_EMAIL="noreply@yourdomain.com"

# === Payment (Tap — Kuwait) ===
TAP_SECRET_KEY=""
TAP_PUBLIC_KEY=""

# === WhatsApp Cloud API ===
WHATSAPP_TOKEN=""
WHATSAPP_PHONE_NUMBER_ID=""

# === Monitoring (Sentry) ===
SENTRY_DSN=""

# === Supabase Client (optional — for Storage/Auth) ===
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
